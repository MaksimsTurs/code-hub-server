{
  "buildCommand": "npm run prod:build",
  "outputDirectory": "output/index.js",
  "builds": [
    {
      "src": "output/index.js",
      "use": "@vercel/node",
      "config": { "includeFiles": ["dist/**"] }
    }
  ],
  "rewrites": [
  	{
    	"source": "/(.*)",
    	"destination": "output/index.js"
    }
  ]
}
